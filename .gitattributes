      { id: 'bear', target: 149.93, label: 'Target: $150', color: '#e05555' },
      { id: 'base', target: 257.00, label: 'Target: $257', color: '#8b949e' },
      { id: 'bull', target: 335.00, label: 'Target: $335', color: '#00c07f' }
    ];
    scenarios.forEach(s => {
      const result = (amt * s.target / current);
      const pct = ((s.target - current) / current * 100);
      document.getElementById(s.id + '-price').textContent = s.label;
      document.getElementById(s.id + '-result').textContent = '$' + Math.round(result).toLocaleString();
      document.getElementById(s.id + '-pct').textContent = (pct >= 0 ? '+' : '') + pct.toFixed(0) + '%';
      document.getElementById(s.id + '-result').style.color = s.color;
      document.getElementById(s.id + '-pct').style.color = s.color;
    });
  }
  updateCalc();

  // --- RISK TOGGLES ---
  function toggleRisk(header) {
    const body = header.nextElementSibling;
    const chevron = header.querySelector('.chevron');
    body.classList.toggle('open');
    chevron.classList.toggle('open');
  }

  // --- QUIZ ---
  const scores = [0, 0, 0, 0, 0];
  let currentStep = 0;

  function answer(q, score) {
    scores[q] = score;
    currentStep++;
    document.getElementById('step-' + q).style.display = 'none';
    const pct = (currentStep / 5) * 100;
    document.getElementById('quiz-prog').style.width = pct + '%';
    if (currentStep < 5) {
      document.getElementById('step-' + currentStep).style.display = 'block';
    } else {
      showResult();
    }
  }

  function showResult() {
    document.getElementById('quiz-questions').style.display = 'none';
    const el = document.getElementById('quiz-result');
    el.style.display = 'block';
    const total = scores.reduce((a, b) => a + b, 0);

    let tag, title, body, color, items;

    if (scores[0] === 0) {
      // Short horizon override — no matter what else
      tag = 'PASS';
      title = 'Not right for you right now';
      color = '#e05555';
      body = 'With a time horizon under a year, Bloom Energy is the wrong vehicle. This stock can drop 40–50% in a quarter on nothing but sentiment. You cannot afford to wait out a valuation reset. <strong>Come back when you have 3+ years of runway.</strong>';
      items = [
        { label: 'Entry price guide', val: 'N/A — don\'t enter' },
        { label: 'Max position size', val: '0%' },
        { label: 'Exit signal', val: 'N/A' },
        { label: 'What to do instead', val: 'Index funds, dividend stocks' }
      ];
    } else if (scores[3] === 0) {
      // Large position size override
      tag = 'CONCENTRATED RISK';
      title = 'Reduce sizing first';
      color = '#e05555';
      body = 'A 20%+ position in a stock at 663× EBITDA is how portfolios get destroyed. Even if you\'re right on the thesis, one bad earnings print can take the stock down 40% in a day. No single idea deserves that much of your net worth at this valuation. <strong>Max 5% position size. Full stop.</strong>';
      items = [
        { label: 'Entry price guide', val: '$220–250 (pullback)' },
        { label: 'Max position size', val: '≤5% of portfolio' },
        { label: 'Exit signal', val: 'Miss on manufacturing ramp' },
        { label: 'Retest this', val: 'After Q2 earnings' }
      ];
    } else if (total <= 4) {
      tag = 'NOT A FIT';
      title = 'Wait for a pullback';
      color = '#f5a623';
      body = 'Your answers suggest this stock would keep you up at night. That\'s not a knock — it means the risk profile doesn\'t match your temperament. At $285, the stock has already surged 1,259%. <strong>If you\'re interested at all, wait for a pullback to the $180–220 range</strong> to get a better risk/reward entry. Set a price alert and walk away until then.';
      items = [
        { label: 'Entry price guide', val: '$180–220 on pullback' },
        { label: 'Max position size', val: '2–3% of portfolio' },
        { label: 'Exit signal', val: 'Manufacturing delay or guidance cut' },
        { label: 'Thesis check point', val: 'Q2 2026 earnings' }
      ];
    } else if (total <= 7) {
      tag = 'CAUTIOUS FIT';
      title = 'Small position, strict rules';
      color = '#4a90d9';
      body = 'You have the patience and conviction this story needs, but the current valuation is stretched and the stock is above analyst consensus. A <strong>small position (3–5% max)</strong> makes sense if you\'re prepared to hold through volatility. Do not average down more than once, and set clear exit conditions before you enter — not after.';
      items = [
        { label: 'Entry price guide', val: 'Current or $250 dip' },
        { label: 'Max position size', val: '3–5% of portfolio' },
        { label: 'Exit signal', val: 'Q2 miss or Brookfield slowdown' },
        { label: 'Horizon', val: '3+ years minimum' }
      ];
    } else {
      tag = 'STRONG FIT';
      title = 'Classic high-risk / high-reward profile';
      color = '#00c07f';
      body = 'You have the time horizon, volatility tolerance, and conviction this story demands. The valuation is stretched, but momentum stocks at inflection points often stay expensive longer than bears expect. <strong>A small, disciplined position (5% max)</strong> fits your profile. Resist the urge to go bigger just because you\'re confident — your edge is patience, not position size.';
      items = [
        { label: 'Entry price guide', val: 'Current price is acceptable' },
        { label: 'Max position size', val: '5% of portfolio' },
        { label: 'Conviction add point', val: '$200–220 on pullback' },
        { label: 'Exit signal', val: 'Manufacturing miss or AI capex cuts' }
      ];
    }

    const box = document.getElementById('result-verdict-box');
    box.style.background = color + '18';
    box.style.border = '1px solid ' + color;
    document.getElementById('result-tag').style.color = color;
    document.getElementById('result-tag').textContent = tag;
    document.getElementById('result-title').textContent = title;
    document.getElementById('result-body').innerHTML = body;

    const grid = document.getElementById('result-grid');
    grid.innerHTML = items.map(i => `
      <div class="result-item">
        <div class="result-item-label">${i.label}</div>
        <div class="result-item-val">${i.val}</div>
      </div>
    `).join('');
  }

  function restartQuiz() {
    currentStep = 0;
    for (let i = 0; i < 5; i++) scores[i] = 0;
    document.getElementById('quiz-questions').style.display = 'block';
    document.getElementById('quiz-result').style.display = 'none';
    document.getElementById('quiz-prog').style.width = '0%';
    for (let i = 0; i < 5; i++) {
      document.getElementById('step-' + i).style.display = i === 0 ? 'block' : 'none';
    }
  }

  // --- LIVE DATA ---
  // Works in two environments:
  //   1. Inside Claude Cowork  -> uses the FMP connector (window.cowork.callMcpTool)
  //   2. On the open web / GitHub Pages -> uses Yahoo Finance via a public CORS proxy
  // Either way it normalizes to { price, change, pct, marketCap, low, high } and renders.
  const SHARES_OUT = 284.45e6; // ~shares outstanding, used to derive market cap on the web source

  function fmtMoney(n) {
    if (n == null || isNaN(n)) return '$—';
    if (n >= 1e12) return '$' + (n / 1e12).toFixed(2) + 'T';
    if (n >= 1e9)  return '$' + (n / 1e9).toFixed(1) + 'B';
    if (n >= 1e6)  return '$' + (n / 1e6).toFixed(0) + 'M';
    return '$' + Math.round(n).toLocaleString();
  }

  // Source A: Cowork connector (only available inside the Cowork app)
  async function fromCowork() {
    const r = await window.cowork.callMcpTool(
      'mcp__d73fc8f8-453d-410e-8685-ddede71bea8a__company',
      { endpoint: 'profile-symbol', symbol: 'BE' }
    );
    const data = r.structuredContent ?? JSON.parse(r.content[0].text);
    const q = Array.isArray(data) ? data[0] : (data.results ? data.results[0] : data);
    if (!q || q.price == null) throw new Error('no price');
    let low = null, high = null;
    if (q.range && q.range.indexOf('-') > -1) {
      const p = q.range.split('-').map(parseFloat);
      low = p[0]; high = p[1];
    }
    return { price: q.price, change: q.change || 0, pct: q.changePercentage || 0,
             marketCap: q.marketCap, low: low, high: high };
  }

  // Source B: Yahoo Finance v8 chart endpoint, tunneled through a public CORS proxy.
  // No API key, so nothing secret is exposed in this public page.
  async function fromYahoo() {
    const url = 'https://query1.finance.yahoo.com/v8/finance/chart/BE?interval=1d&range=1d';
    const proxies = [
      function (u) { return 'https://corsproxy.io/?url=' + encodeURIComponent(u); },
      function (u) { return 'https://api.allorigins.win/raw?url=' + encodeURIComponent(u); }
    ];
    let meta = null;
    for (const wrap of proxies) {
      try {
        const res = await fetch(wrap(url), { cache: 'no-store' });
        if (!res.ok) continue;
        const j = await res.json();
        meta = j.chart.result[0].meta;
        if (meta && meta.regularMarketPrice != null) break;
        meta = null;
      } catch (e) { /* try next proxy */ }
    }
    if (!meta) throw new Error('all proxies failed');
    const price = meta.regularMarketPrice;
    const prev = meta.previousClose != null ? meta.previousClose : meta.chartPreviousClose;
    const change = prev != null ? price - prev : 0;
    const pct = prev ? (change / prev) * 100 : 0;
    return { price: price, change: change, pct: pct,
             marketCap: price * SHARES_OUT,
             low: meta.fiftyTwoWeekLow, high: meta.fiftyTwoWeekHigh };
  }

  function render(d) {
    const price = d.price;
    LIVE_PRICE = price;

    document.getElementById('live-price').textContent =
      '$' + price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    const chgEl = document.getElementById('live-change');
    const up = d.change >= 0;
    chgEl.textContent = (up ? '▲ +' : '▼ ') + d.change.toFixed(2) + ' (' + (up ? '+' : '') + d.pct.toFixed(2) + '%) today';
    chgEl.className = 'stat-sub ' + (up ? 'up' : 'down');

    if (d.marketCap != null) {
      document.getElementById('live-mcap').textContent = fmtMoney(d.marketCap);
      document.getElementById('live-mcap-sub').textContent = 'Large-cap';
    }

    if (d.low != null && d.high != null && d.high > d.low) {
      const posPct = Math.max(0, Math.min(100, ((price - d.low) / (d.high - d.low)) * 100));
      document.getElementById('range-marker').style.left = posPct.toFixed(1) + '%';
      document.getElementById('range-low').textContent = '$' + d.low.toFixed(2);
      document.getElementById('range-high').textContent = '$' + d.high.toFixed(2);
      document.getElementById('range-here').textContent =
        '$' + price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      document.getElementById('range-label').textContent =
        '52-week price range — where $' + price.toFixed(0) + ' sits today (' + posPct.toFixed(0) + '% of range)';
    }

    document.getElementById('live-asof').textContent =
      new Date().toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });

    updateCalc();
  }

  async function loadLive() {
    try {
      const hasCowork = (typeof window !== 'undefined' && window.cowork && window.cowork.callMcpTool);
      const d = hasCowork ? await fromCowork() : await fromYahoo();
      render(d);
    } catch (e) {
      document.getElementById('live-asof').textContent = 'price unavailable';
      document.getElementById('live-price').textContent = '$' + LIVE_PRICE.toFixed(2);
      document.getElementById('live-change').textContent = 'live fetch failed — showing last known snapshot';
    }
  }

  loadLive();
</script>
